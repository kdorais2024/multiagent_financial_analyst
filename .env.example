# =============================================================================
# Multi-Agent Financial Research Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Shared LLM settings
LLM_TEMPERATURE=0.1

# --- Data Source APIs --------------------------------------------------------
# NewsAPI — get a free key at https://newsapi.org/register
# Leave blank to use mock data for development
NEWS_API_KEY=your_newsapi_key_here

# SEC EDGAR — required: your name and email (SEC policy)
SEC_EDGAR_USER_AGENT=YourName your_email@example.com

# --- LangSmith Observability -------------------------------------------------
# Sign up at https://smith.langchain.com/ for free
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=financial-research-agent

# --- Vector Store ------------------------------------------------------------
FAISS_INDEX_PATH=data/faiss_index
EMBEDDING_MODEL=text-embedding-3-small

# --- Application -------------------------------------------------------------
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
